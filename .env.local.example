# Copy this file to `.env.local` only when you want machine-specific overrides.
# Important: `.env.local` overrides `.env`, so leave unused variables commented out.
# Uncomment only the keys you really want to override on your machine.

# APP_ENV: override the shared app mode for this machine.
# APP_ENV=development

# HTTP_ADDR: override the API listen address.
# HTTP_ADDR=:8080

# HTTP_READ_TIMEOUT: override request read timeout.
# HTTP_READ_TIMEOUT=5s

# HTTP_WRITE_TIMEOUT: override response write timeout.
# HTTP_WRITE_TIMEOUT=10s

# HTTP_IDLE_TIMEOUT: override idle keep-alive timeout.
# HTTP_IDLE_TIMEOUT=30s

# HTTP_REQUEST_TIMEOUT: override API request deadline.
# HTTP_REQUEST_TIMEOUT=30s

# HTTP_READINESS_TIMEOUT: override readiness check timeout.
# HTTP_READINESS_TIMEOUT=2s

# HTTP_SHUTDOWN_TIMEOUT: override graceful shutdown timeout.
# HTTP_SHUTDOWN_TIMEOUT=10s

# DB_URL: full DSN override. Useful if you do not want to manage POSTGRES_* separately.
# DB_URL=postgres://postgres:postgres@localhost:5433/vpn_mvp?sslmode=disable

# POSTGRES_HOST: database host override.
# POSTGRES_HOST=localhost

# POSTGRES_PORT: database port override.
# POSTGRES_PORT=5433

# POSTGRES_DB: database name override.
# POSTGRES_DB=vpn_mvp

# POSTGRES_USER: database user override.
# POSTGRES_USER=postgres

# POSTGRES_PASSWORD: database password override.
# POSTGRES_PASSWORD=postgres

# POSTGRES_SSL_MODE: database SSL mode override.
# POSTGRES_SSL_MODE=disable

# DB_MAX_CONNS: optional pgx max pool size override.
# DB_MAX_CONNS=10

# DB_MIN_CONNS: optional pgx min pool size override.
# DB_MIN_CONNS=2

# DB_MAX_CONN_LIFETIME: optional max DB connection lifetime override.
# DB_MAX_CONN_LIFETIME=30m

# DB_MAX_CONN_IDLE_TIME: optional max DB idle time override.
# DB_MAX_CONN_IDLE_TIME=5m

# DB_HEALTH_CHECK_PERIOD: optional DB health-check cadence override.
# DB_HEALTH_CHECK_PERIOD=1m

# DEVICE_PRIVATE_KEY_CIPHER_KEY: generated with `openssl rand -base64 32`.
# Keep stable per environment if you want to resend existing device configs.
# DEVICE_PRIVATE_KEY_CIPHER_KEY=

# VPN_SERVER_PUBLIC_KEY: get from `sudo wg show wg-clients public-key` on the listener host.
# VPN_SERVER_PUBLIC_KEY=

# VPN_SERVER_ENDPOINT: client-visible UDP endpoint, for example `111.88.157.89:51821`.
# VPN_SERVER_ENDPOINT=

# VPN_SERVER_TUNNEL_ADDRESS: server-side client subnet, for example from `wg-clients.conf`.
# VPN_SERVER_TUNNEL_ADDRESS=

# VPN_ALLOWED_IPS: comma-separated client routes. Use `0.0.0.0/0` for full tunnel.
# VPN_ALLOWED_IPS=

# VPN_DNS: comma-separated DNS servers written into generated client configs.
# VPN_DNS=1.1.1.1

# VPN_PERSISTENT_KEEPALIVE: keepalive seconds, commonly `25`.
# VPN_PERSISTENT_KEEPALIVE=25

# PROXY_SSH_HOST: provisioning target host/IP or SSH alias like `yc-vpnmgr`.
# PROXY_SSH_HOST=

# PROXY_SSH_PORT: provisioning SSH port.
# PROXY_SSH_PORT=22

# PROXY_SSH_USER: provisioning SSH user.
# PROXY_SSH_USER=vpnmgr

# PROXY_SSH_CONFIG_PATH: dedicated OpenSSH config file path.
# PROXY_SSH_CONFIG_PATH=/run/secrets/ssh_config.app

# PROXY_SSH_PRIVATE_KEY_PATH: private key path for native Go SSH fallback mode only.
# PROXY_SSH_PRIVATE_KEY_PATH=/run/secrets/proxy_ssh_key

# PROXY_SSH_KNOWN_HOSTS_PATH: known_hosts path for native Go SSH fallback mode only.
# PROXY_SSH_KNOWN_HOSTS_PATH=/run/secrets/proxy_known_hosts

# PROXY_SSH_INSECURE_SKIP_HOST_KEY_CHECK: only for bootstrap/debug emergencies.
# PROXY_SSH_INSECURE_SKIP_HOST_KEY_CHECK=false

# PROXY_ADD_PEER_COMMAND: remote add-peer command.
# PROXY_ADD_PEER_COMMAND=sudo -n /usr/local/bin/vpn-peer-add

# PROXY_REMOVE_PEER_COMMAND: remote remove-peer command.
# PROXY_REMOVE_PEER_COMMAND=sudo -n /usr/local/bin/vpn-peer-remove

# PROXY_SSH_TIMEOUT: provisioning SSH timeout.
# PROXY_SSH_TIMEOUT=5s

# TELEGRAM_BOT_TOKEN: BotFather token override.
# TELEGRAM_BOT_TOKEN=

# TELEGRAM_POLL_TIMEOUT: Telegram long-poll timeout override.
# TELEGRAM_POLL_TIMEOUT=30s

# BACKEND_API_BASE_URL: bot -> API base URL override.
# BACKEND_API_BASE_URL=http://127.0.0.1:8080

# BACKEND_API_TIMEOUT: bot -> API timeout override.
# BACKEND_API_TIMEOUT=5s
