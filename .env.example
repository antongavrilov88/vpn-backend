# Copy this file to `.env` for shared local defaults.
# Real secrets belong in ignored local files only.
#
# Loading order in code is:
# 1. `.env`
# 2. `.env.local` overrides `.env`

# APP_ENV: application mode.
# Use `development` locally and `production` on the app host.
APP_ENV=development

# HTTP_ADDR: listen address for the API process.
# Local default is `:8080`.
HTTP_ADDR=:8080

# HTTP_READ_TIMEOUT: max time to read the request.
# Usually keep the code default unless you have a real reason to change it.
HTTP_READ_TIMEOUT=5s

# HTTP_WRITE_TIMEOUT: max time to write the response.
HTTP_WRITE_TIMEOUT=10s

# HTTP_IDLE_TIMEOUT: keep-alive timeout for idle HTTP connections.
HTTP_IDLE_TIMEOUT=30s

# HTTP_REQUEST_TIMEOUT: outer request deadline enforced by the API.
HTTP_REQUEST_TIMEOUT=30s

# HTTP_READINESS_TIMEOUT: timeout used by readiness checks.
HTTP_READINESS_TIMEOUT=2s

# HTTP_SHUTDOWN_TIMEOUT: graceful shutdown window for the API process.
HTTP_SHUTDOWN_TIMEOUT=10s

# DB_URL: optional full Postgres DSN override.
# Leave empty when you want the app to build the DSN from POSTGRES_* below.
# Example:
# DB_URL=postgres://postgres:postgres@localhost:5433/vpn_mvp?sslmode=disable
DB_URL=

# POSTGRES_HOST: database host for local development.
# With `make db-up`, the local default is `localhost`.
POSTGRES_HOST=localhost

# POSTGRES_PORT: database port for local development.
# The local Docker Compose stack exposes Postgres on `5433`.
POSTGRES_PORT=5433

# POSTGRES_DB: database name.
# Match the local Makefile / compose defaults unless you intentionally changed them.
POSTGRES_DB=vpn_mvp

# POSTGRES_USER: database username.
POSTGRES_USER=postgres

# POSTGRES_PASSWORD: database password.
POSTGRES_PASSWORD=postgres

# POSTGRES_SSL_MODE: Postgres SSL mode.
# Local Docker Compose uses `disable`. Managed databases often use `require`.
POSTGRES_SSL_MODE=disable

# DB_MAX_CONNS: optional pgx pool upper bound.
# Leave empty for local defaults; set in staging/prod when you want explicit control.
DB_MAX_CONNS=

# DB_MIN_CONNS: optional pgx pool minimum idle connections.
DB_MIN_CONNS=

# DB_MAX_CONN_LIFETIME: optional max lifetime per DB connection.
DB_MAX_CONN_LIFETIME=

# DB_MAX_CONN_IDLE_TIME: optional max idle time per DB connection.
DB_MAX_CONN_IDLE_TIME=

# DB_HEALTH_CHECK_PERIOD: optional pgx pool health-check interval.
DB_HEALTH_CHECK_PERIOD=

# DEVICE_PRIVATE_KEY_CIPHER_KEY: symmetric key used to encrypt stored client private keys.
# Generate it once with:
#   openssl rand -base64 32
# Keep it stable for one environment, otherwise old device configs cannot be decrypted.
DEVICE_PRIVATE_KEY_CIPHER_KEY=

# VPN_SERVER_PUBLIC_KEY: public key of the server-facing WireGuard listener that clients connect to.
# For the current YC contour, get it from:
#   sudo wg show wg-clients public-key
VPN_SERVER_PUBLIC_KEY=

# VPN_SERVER_ENDPOINT: public UDP endpoint that clients should dial.
# Format: <host-or-ip>:<port>
# Example for the current contour:
#   111.88.157.89:51821
VPN_SERVER_ENDPOINT=

# VPN_SERVER_TUNNEL_ADDRESS: server-side address/subnet of the client-facing WireGuard interface.
# Get it from the listener config on the VPN server, for example `Address = ...` in `wg-clients.conf`.
VPN_SERVER_TUNNEL_ADDRESS=

# VPN_ALLOWED_IPS: routes pushed to generated client configs.
# Use `0.0.0.0/0` for a full-tunnel client.
# Leave empty to let the backend apply its default full-tunnel behavior.
VPN_ALLOWED_IPS=

# VPN_DNS: comma-separated DNS servers written into generated client configs.
# Example: `1.1.1.1` or `1.1.1.1,8.8.8.8`
VPN_DNS=

# VPN_PERSISTENT_KEEPALIVE: optional WireGuard keepalive in seconds.
# `25` is a common value for roaming/NATed clients.
VPN_PERSISTENT_KEEPALIVE=25

# PROXY_SSH_HOST: SSH target used for peer provisioning.
# When PROXY_SSH_CONFIG_PATH is set, this may be an SSH alias such as `yc-vpnmgr`.
# Without a dedicated SSH config, use the real host/IP.
PROXY_SSH_HOST=

# PROXY_SSH_PORT: SSH port for the provisioning target.
PROXY_SSH_PORT=22

# PROXY_SSH_USER: SSH user for provisioning.
# Example: `vpnmgr`
PROXY_SSH_USER=

# PROXY_SSH_CONFIG_PATH: optional dedicated OpenSSH config file.
# When set, the backend shells out to `ssh -F <this-file>` and does not rely on `/etc/ssh/ssh_config`.
# In containerized prod this is usually `/run/secrets/ssh_config.app`.
PROXY_SSH_CONFIG_PATH=

# PROXY_SSH_PRIVATE_KEY_PATH: private key path for the native Go SSH fallback path.
# Only needed when PROXY_SSH_CONFIG_PATH is empty.
# In containerized prod this is usually `/run/secrets/proxy_ssh_key`.
PROXY_SSH_PRIVATE_KEY_PATH=

# PROXY_SSH_KNOWN_HOSTS_PATH: known_hosts file for SSH host verification.
# Only needed for the native Go SSH fallback path.
# In containerized prod this is usually `/run/secrets/proxy_known_hosts`.
PROXY_SSH_KNOWN_HOSTS_PATH=

# PROXY_SSH_INSECURE_SKIP_HOST_KEY_CHECK: emergency bootstrap escape hatch.
# Prefer `false`; set to `true` only when you intentionally want to bypass host-key verification.
PROXY_SSH_INSECURE_SKIP_HOST_KEY_CHECK=false

# PROXY_ADD_PEER_COMMAND: remote command used to add a peer on the VPN host.
# Keep it aligned with docs/proxy-peer-management.md.
# Prefer `sudo -n` so the backend fails fast instead of hanging on a password prompt.
PROXY_ADD_PEER_COMMAND=sudo -n /usr/local/bin/vpn-peer-add

# PROXY_REMOVE_PEER_COMMAND: remote command used to remove/revoke a peer on the VPN host.
PROXY_REMOVE_PEER_COMMAND=sudo -n /usr/local/bin/vpn-peer-remove

# PROXY_SSH_TIMEOUT: end-to-end timeout for the provisioning SSH step.
PROXY_SSH_TIMEOUT=5s

# TELEGRAM_BOT_TOKEN: token from BotFather.
# Needed only when you run the bot.
TELEGRAM_BOT_TOKEN=

# TELEGRAM_POLL_TIMEOUT: long-poll timeout used by the bot.
TELEGRAM_POLL_TIMEOUT=30s

# BACKEND_API_BASE_URL: API base URL used by the bot process.
# For local `make api-run` + `make bot-run`, `http://127.0.0.1:8080` is the usual value.
# For Docker Compose bot->api traffic, use the Compose service URL such as `http://api:8080`.
BACKEND_API_BASE_URL=http://127.0.0.1:8080

# BACKEND_API_TIMEOUT: request timeout used by the bot when calling the API.
BACKEND_API_TIMEOUT=5s
